CC=gcc
CFLAGS=-std=c11 -Wpedantic -Wall -Wextra
LDLIBS=-lm
RM=rm -f
OBJ=visuarbreasc.o identite.o genea.o
EXE=visuarbreasc
$(EXE):$(OBJ)
		$(CC) $(CFLAGS) $(OBJ) -o $(EXE) $(LDLIBS)
visuarbreasc.o:visuarbreasc.c identite.h genea.h
		$(CC) $(CFLAGS) -c visuarbreasc.c
identite.o: identite.c identite.h
		$(CC) $(CFLAGS) -c identite.c
genea.o: genea.c genea.h
		$(CC) $(CFLAGS) -c genea.c		
clean:
		$(RM) $(OBJ) $(EXE)