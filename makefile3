CC=gcc
CFLAGS=-std=c11 -Wpedantic -Wall -Wextra
LDLIBS=-lm
RM=rm -f
OBJ=visuarbre.o identite.o genea.o
EXE=visuarbre
$(EXE):$(OBJ)
		$(CC) $(CFLAGS) $(OBJ) -o $(EXE) $(LDLIBS)
visuarbre.o:visuarbre.c identite.h genea.h
		$(CC) $(CFLAGS) -c visuarbre.c
identite.o: identite.c identite.h
		$(CC) $(CFLAGS) -c identite.c
genea.o: genea.c genea.h
		$(CC) $(CFLAGS) -c genea.c		
clean:
		$(RM) $(OBJ) $(EXE)
